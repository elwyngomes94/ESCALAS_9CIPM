{
  "entities": {
    "Policeman": {
      "title": "Policial",
      "description": "Dados do policial militar",
      "type": "object",
      "properties": {
        "nomeCompleto": { "type": "string" },
        "nomeGuerra": { "type": "string" },
        "graduacaoPosto": { "type": "string" },
        "matricula": { "type": "string" },
        "telefone": { "type": "string" },
        "situacao": { "type": "string" },
        "pjesCotasMax": { "type": "number" },
        "opsCotasMax": { "type": "number" }
      },
      "required": ["nomeCompleto", "nomeGuerra", "graduacaoPosto", "matricula"]
    },
    "ServiceType": {
      "title": "Tipo de Serviço",
      "description": "Configuração de modalidade de serviço (PJES/OPS)",
      "type": "object",
      "properties": {
        "nome": { "type": "string" },
        "tipo": { "type": "string", "enum": ["PJES", "OPS", "ORDINARIO", "EXTRA"] },
        "sigla": { "type": "string" },
        "cidade": { "type": "string" },
        "horarioInicio": { "type": "string" },
        "horarioTermino": { "type": "string" },
        "cotasPorServico": { "type": "number" },
        "isActive": { "type": "boolean" },
        "month": { "type": "string" },
        "vagasNecessarias": { "type": "number" }
      },
      "required": ["nome", "tipo", "sigla", "cotasPorServico", "isActive"]
    },
    "Escala": {
      "title": "Escala",
      "description": "Vinculação de policiais a um serviço numa data",
      "type": "object",
      "properties": {
        "serviceTypeId": { "type": "string" },
        "policemenIds": { "type": "array" },
        "date": { "type": "string", "format": "date-time" },
        "observations": { "type": "string" }
      },
      "required": ["serviceTypeId", "policemenIds", "date"]
    },
    "QuotaLog": {
      "title": "Log de Cota",
      "description": "Registro de consumo de cota por policial/serviço",
      "type": "object",
      "properties": {
        "serviceTypeId": { "type": "string" },
        "policemanId": { "type": "string" },
        "escalaId": { "type": "string" },
        "tipo": { "type": "string" },
        "quantidade": { "type": "number" },
        "month": { "type": "string" },
        "usuarioUid": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/policemen/{policemanId}": {
      "schema": "Policeman",
      "description": "Lista de efetivo"
    },
    "/serviceTypes/{serviceTypeId}": {
      "schema": "ServiceType",
      "description": "Modalidades de serviço configuradas"
    },
    "/escalas/{escalaId}": {
      "schema": "Escala",
      "description": "Lançamentos de escala"
    },
    "/quotaLogs/{logId}": {
      "schema": "QuotaLog",
      "description": "Logs de consumo de cota"
    }
  }
}
