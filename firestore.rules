rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function currentEmail() {
      return request.auth.token.email;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'elwyn.gomes94@gmail.com' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Helpers
    function isValidPoliceman(d) {
      return d.nomeCompleto is string && d.nomeGuerra is string && 
             d.graduacaoPosto is string && d.matricula is string;
    }

    function isValidServiceType(d) {
      return d.nome is string && d.tipo is string && d.sigla is string &&
             d.cotasPorServico is number && d.month is string;
    }

    function isValidQuotaLog(d) {
      return d.serviceTypeId is string && d.tipo is string &&
             d.quantidade is number && d.month is string;
    }

    function isValidQuotaSettings(d) {
      return d.month is string && d.opsTotal is number;
    }

    function isValidVolunteer(d) {
      return d.policemanId is string && d.type is string &&
             d.cotas is number;
    }

    function isValidEscala(d) {
      return d.serviceTypeId is string &&
             d.policemenIds is list && d.policemenIds.size() > 0 &&
             (d.date is timestamp || d.date is string);
    }

    // Rules
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId && 
                     incoming().email == currentEmail() && 
                     incoming().isAdmin == (currentEmail() == 'elwyn.gomes94@gmail.com');
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['email']) );
    }

    match /policemen/{policemanId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(policemanId) && 
                                    (request.method == 'delete' || isValidPoliceman(incoming()));
    }

    match /serviceTypes/{serviceTypeId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(serviceTypeId) &&
                                    (request.method == 'delete' || isValidServiceType(incoming()));
    }

    match /volunteers/{volunteerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(volunteerId) &&
                                    (request.method == 'delete' || isValidVolunteer(incoming()));
    }

    match /escalas/{escalaId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && isValidId(escalaId) &&
                                    (request.method == 'delete' || isValidEscala(incoming()));
    }

    match /ordinarySchedules/{scheduleId} {
      allow read: if true;
      allow create, update, delete: if (isAdmin() || true) && isValidId(scheduleId);
    }

    match /quotaSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(settingId) && isValidQuotaSettings(incoming());
    }

    match /quotaLogs/{logId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidQuotaLog(incoming());
      allow update, delete: if isAdmin();
    }
  }
}
