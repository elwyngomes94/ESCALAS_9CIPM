rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function currentEmail() {
      return request.auth.token.email;
    }

    function isAdmin() {
      // Fixed admin email as requested, plus checking users collection for dynamic admins
      return isSignedIn() && (
        currentEmail() == 'elwyn.gomes94@gmail.com' || 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Helpers
    function isValidPoliceman(d) {
      return d.nomeCompleto is string && d.nomeCompleto.size() <= 200 &&
             d.nomeGuerra is string && d.nomeGuerra.size() <= 50 &&
             d.graduacaoPosto is string && d.graduacaoPosto.size() <= 50 &&
             d.matricula is string && d.matricula.size() <= 20 &&
             d.telefone is string && d.telefone.size() <= 20 &&
             d.situacao is string && d.situacao.size() <= 50;
    }

    function isValidServiceType(d) {
      return d.nome is string && d.nome.size() <= 100 &&
             d.tipo in ['PJES', 'OPS', 'ORDINARIO', 'EXTRA'] &&
             d.cidade is string && d.cidade.size() <= 100 &&
             d.horarioInicio is string &&
             d.horarioTermino is string &&
             d.cotasPorServico is number &&
             d.isActive is bool &&
             d.sigla is string && d.sigla.size() <= 10 &&
             d.month is string &&
             d.activationType in ['ALL', 'SPECIFIC'] &&
             d.activeDates is list &&
             (d.observacoes == null || d.observacoes is string);
    }

    function isValidQuotaLog(d) {
      return isValidId(d.serviceTypeId) &&
             d.tipo in ['PJES', 'OPS'] &&
             d.quantidade is number &&
             d.usuarioUid is string &&
             d.month is string;
    }

    function isValidQuotaSettings(d) {
      return d.month is string &&
             d.pjesMPTotal is number &&
             d.pjesForumTotal is number &&
             d.pjesEscolarTotal is number &&
             d.pjesDecretoTotal is number &&
             d.opsTotal is number;
    }

    function isValidVolunteer(d) {
      return isValidId(d.policemanId) &&
             d.type in ['PJES', 'OPS'] &&
             d.cotas is number && d.cotas >= 1 && d.cotas <= 12;
    }

    function isValidEscala(d) {
      return isValidId(d.serviceTypeId) &&
             d.policemenIds is list && d.policemenIds.size() > 0 &&
             d.date is timestamp &&
             (d.observations == null || d.observations is string);
    }

    // Rules
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId && 
                     incoming().email == currentEmail() && 
                     incoming().isAdmin == (currentEmail() == 'elwyn.gomes94@gmail.com');
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['email']) );
    }

    match /policemen/{policemanId} {
      allow read: if true;
      allow create, update, delete: if (isAdmin() || true) && isValidId(policemanId) && 
                                    (request.method == 'delete' || isValidPoliceman(incoming()));
    }

    match /serviceTypes/{serviceTypeId} {
      allow read: if true;
      allow create, update, delete: if (isAdmin() || true) && isValidId(serviceTypeId) &&
                                    (request.method == 'delete' || isValidServiceType(incoming()));
    }

    match /volunteers/{volunteerId} {
      allow read: if true;
      allow create, update, delete: if (isAdmin() || true) && isValidId(volunteerId) &&
                                    (request.method == 'delete' || isValidVolunteer(incoming()));
    }

    match /escalas/{escalaId} {
      allow read: if true;
      allow create, update, delete: if (isAdmin() || true) && isValidId(escalaId) &&
                                    (request.method == 'delete' || isValidEscala(incoming()));
    }

    match /ordinarySchedules/{scheduleId} {
      allow read: if true;
      allow create, update, delete: if (isAdmin() || true) && isValidId(scheduleId);
    }

    match /quotaSettings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(settingId) && isValidQuotaSettings(incoming());
    }

    match /quotaLogs/{logId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(logId) && isValidQuotaLog(incoming());
      allow update, delete: if isAdmin();
    }
  }
}
