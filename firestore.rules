rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function currentEmail() {
      return request.auth.token.email;
    }

    function isAdmin() {
      // Fixed admin email as requested, plus checking users collection for dynamic admins
      return isSignedIn() && (
        currentEmail() == 'elwyn.gomes94@gmail.com' || 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Helpers
    function isValidPoliceman(d) {
      return d.nomeCompleto is string && 
             d.nomeGuerra is string && 
             d.graduacaoPosto is string && 
             d.matricula is string && 
             d.telefone is string && 
             d.situacao is string;
    }

    function isValidServiceType(d) {
      return d.nome is string && 
             d.tipo is string &&
             d.cidade is string && 
             d.horarioInicio is string &&
             d.horarioTermino is string &&
             d.cotasPorServico is number &&
             d.isActive is bool &&
             d.sigla is string && 
             d.month is string &&
             d.activationType is string &&
             d.activeDates is list;
    }

    function isValidQuotaLog(d) {
      return d.serviceTypeId is string &&
             d.tipo is string &&
             d.quantidade is number &&
             d.usuarioUid is string &&
             d.month is string;
    }

    function isValidQuotaSettings(d) {
      return d.month is string &&
             d.pjesMPTotal is number &&
             d.pjesForumTotal is number &&
             d.pjesEscolarTotal is number &&
             d.pjesDecretoTotal is number &&
             d.opsTotal is number;
    }

    function isValidVolunteer(d) {
      return d.policemanId is string &&
             d.type is string &&
             d.cotas is number;
    }

    function isValidEscala(d) {
      return d.serviceTypeId is string &&
             d.policemenIds is list && 
             d.date is timestamp;
    }

    // Rules
    match /users/{userId} {
      allow read, write: if true;
    }

    match /policemen/{policemanId} {
      allow read, write: if true;
    }

    match /serviceTypes/{serviceTypeId} {
      allow read, write: if true;
    }

    match /volunteers/{volunteerId} {
      allow read, write: if true;
    }

    match /escalas/{escalaId} {
      allow read, write: if true;
    }

    match /ordinarySchedules/{scheduleId} {
      allow read, write: if true;
    }

    match /quotaSettings/{settingId} {
      allow read, write: if true;
    }

    match /quotaLogs/{logId} {
      allow read, write: if true;
    }
  }
}
